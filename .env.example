# 基础设施连接（docker-compose 服务名 redis/postgres）
INBOX_REDIS_URL=redis://redis:6379/0
INBOX_DATABASE_URL=postgresql+asyncpg://inbox:inbox@postgres:5432/inbox

# 部署级密钥（每客部署唯一，必须配置）
INBOX_MASTER_KEY=  # 凭据加密主密钥：openssl rand -base64 32 生成
INBOX_ADMIN_API_KEY=  # API 鉴权 key（X-API-Key），自定义

# 服务
INBOX_HOST=0.0.0.0
INBOX_PORT=8000
INBOX_LOG_LEVEL=INFO

# 业务凭据（channels.yaml 通过 ${ENV} 引用，按需填）
TELEGRAM_BOT_TOKEN=
DIDA365_ACCESS_TOKEN=
GITHUB_TOKEN=
CUBOX_API_KEY=
FLOMO_WEBHOOK=
JIANGUOYUN_USER=
JIANGUOYUN_PASS=
Z_AI_API_KEY=
