# 渠道配置（客户私有化部署时拷贝改名 channels.yaml，填真实凭据到 .env）
# ${ENV} 从环境变量插值，凭据不落 yaml 明文

sources:
  telegram:
    enabled: true
    config: {bot_token: "${TELEGRAM_BOT_TOKEN}"}
  dida:
    enabled: true
    config: {access_token: "${DIDA365_ACCESS_TOKEN}"}
  github_stars:
    enabled: true
    config: {token: "${GITHUB_TOKEN}"}
  # zhihu:  # 浏览器源：需先 POST /login/zhihu/cookie 配 z_c0（阶段3 命门已验证）
  #   enabled: false
  #   kind: BROWSER
  #   config: {collection_id: "你的收藏夹ID", credential_name: "zhihu_creds"}
  # bilibili:  # 浏览器源：需先 POST /login/bilibili/cookie 配 SESSDATA
  #   enabled: false
  #   kind: BROWSER
  #   config: {media_id: "你的B站收藏夹ID", credential_name: "bilibili_creds"}
  #   # 注意：B站用 media_id（收藏夹 ID），不是 collection_id（那是知乎的 key）

destinations:
  cubox:
    enabled: true
    item_kind: link
    config: {api_url: "${CUBOX_API_KEY}"}
  flomo:
    enabled: true
    item_kind: text
    config: {webhook: "${FLOMO_WEBHOOK}"}
  jianguoyun:
    enabled: true
    item_kind: file
    config: {webdav_user: "${JIANGUOYUN_WEBDAV_USER}", webdav_pass: "${JIANGUOYUN_WEBDAV_PASS}"}

# 仅归档功能上线后 Cubox 成功的新链接；worker 需挂载宿主机 ~/.agents，GITHUB_TOKEN 需有写权限。
article_archive:
  enabled: false
  repository_dir: /article-repository
  articles_dir: references/article
  min_visible_characters: 200
  http_timeout_seconds: 30
  browser_timeout_seconds: 45
  defuddle_timeout_seconds: 30
  max_html_bytes: 8000000
  max_output_bytes: 10000000
  enqueue_attempts: 3
  rate_window_count: 60
  rate_window_seconds: 3600
  daily_limit: 10000
  interval_seconds: 5

credentials: {}
#   zhihu_creds: {platform: zhihu, kind: cookie, vault_id: "zhihu_main"}

llm:
  glm_api_key: "${Z_AI_API_KEY}"
  model: "glm-4-flash"
